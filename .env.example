# === Только бот (запуск: py main.py) ===
BOT_TOKEN=your_telegram_bot_token_from_BotFather
ADMIN_IDS=123456789
DATABASE_URL=sqlite+aiosqlite:///./bot.db
REFERRAL_PERCENT_UP_TO_10=20
REFERRAL_PERCENT_AFTER_10=5
REFERRAL_COUNT_THRESHOLD=10
REFERRAL_FIRST_TASK_BONUS=0
APP_TIMEZONE=Europe/Moscow
TASK_CLAIM_MINUTES=60
# Опционально: ссылка на Telegram-канал, куда публикуются одобренные отзывы (показывается в профиле)
# REVIEWS_CHANNEL_URL=https://t.me/your_reviews_channel
# Ежедневный отчёт админам: остаток отзывов по платформам (время по APP_TIMEZONE)
REVIEWS_STOCK_REPORT_HOUR=22
REVIEWS_STOCK_REPORT_MINUTE=0
YANDEX_QUIZ_FREEZE_HOURS=4
YANDEX_ANSWER_MIN_SECONDS=5
YANDEX_CHEAT_BAN_DAYS=7
PAYMENTS_API_BASE_URL=https://api-payments.konsol.pro
PAYMENTS_API_AUTH=Bearer your_api_token
PAYMENTS_API_TIMEOUT_SECONDS=20

# === Веб-админка (run_web.py / run_all.py; на VPS: WEB_HOST=127.0.0.1) ===
WEB_ADMIN_PASSWORD=change_me_strong
WEB_SESSION_SECRET=change_me_random_32_chars_minimum
WEB_HOST=0.0.0.0
WEB_PORT=8000
