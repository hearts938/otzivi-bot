[Unit]
Description=Review bot — Telegram polling
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/pythonboteng
EnvironmentFile=/opt/pythonboteng/.env
ExecStart=/opt/pythonboteng/venv/bin/python main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
